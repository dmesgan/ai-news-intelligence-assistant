#!/bin/sh
# Apache Maven Wrapper startup script
# Licensed to the Apache Software Foundation (ASF) under one or more
# contributor license agreements.

set -e

if [ -z "$JAVA_HOME" ] ; then
  JAVACMD=java
else
  JAVACMD="$JAVA_HOME/bin/java"
fi

if [ ! -x "$JAVACMD" ] && [ ! -x "$(command -v java)" ] ; then
  echo "Error: JAVA_HOME is not set and no 'java' command found in PATH."
  exit 1
fi

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(pwd)}"
WRAPPERDIR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
WRAPPER_PROPERTIES="$WRAPPERDIR/maven-wrapper.properties"

if [ -f "$WRAPPER_PROPERTIES" ]; then
  DISTRIBUTION_URL=$(grep "distributionUrl" "$WRAPPER_PROPERTIES" | cut -d= -f2-)
else
  DISTRIBUTION_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.9/apache-maven-3.9.9-bin.zip"
fi

MAVEN_VERSION=$(echo "$DISTRIBUTION_URL" | sed 's/.*apache-maven-\([0-9.]*\)-.*/\1/')
MAVEN_HOME="${HOME}/.m2/wrapper/dists/apache-maven-${MAVEN_VERSION}-bin"
MAVEN_CMD="$MAVEN_HOME/apache-maven-${MAVEN_VERSION}/bin/mvn"

if [ ! -x "$MAVEN_CMD" ]; then
  echo "Downloading Maven $MAVEN_VERSION ..."
  mkdir -p "$MAVEN_HOME"
  TMP_ZIP="$MAVEN_HOME/maven.zip"
  if command -v curl > /dev/null 2>&1; then
    curl -fsSL -o "$TMP_ZIP" "$DISTRIBUTION_URL"
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "$TMP_ZIP" "$DISTRIBUTION_URL"
  else
    echo "Error: curl or wget is required to download Maven."
    exit 1
  fi
  unzip -q "$TMP_ZIP" -d "$MAVEN_HOME"
  rm -f "$TMP_ZIP"
  echo "Maven $MAVEN_VERSION downloaded."
fi

exec "$MAVEN_CMD" "$@"
